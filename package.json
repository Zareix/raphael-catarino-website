    "astro": "7.0.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "open-props": "^1.7.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "vaul": "^1.1.2",
